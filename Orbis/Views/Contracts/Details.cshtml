@model Orbis.Models.Contract

@{
    ViewData["Title"] = "Детали договора";
}

<h1>Детали договора страхования</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Номер договора</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.ContractNumber)</dd>
        
        <dt class="col-sm-3">Дата заключения</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.ContractDate)</dd>
        
        <dt class="col-sm-3">Клиент</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Person.Name) (@Model.Person.PersonType)</dd>
        
        <dt class="col-sm-3">Услуга страхования</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.InsuranceService.Name)</dd>
        
        <dt class="col-sm-3">Период действия</dt>
        <dd class="col-sm-9">с @Model.StartDate.ToShortDateString() по @Model.EndDate.ToShortDateString()</dd>
        
        <dt class="col-sm-3">Сумма договора</dt>
        <dd class="col-sm-9">@Model.Amount.ToString("C")</dd>
        
        <dt class="col-sm-3">Статус</dt>
        <dd class="col-sm-9">
            @if (Model.Status == "Активный")
            {
                <span class="badge bg-success">@Model.Status</span>
            }
            else if (Model.Status == "Просрочен")
            {
                <span class="badge bg-danger">@Model.Status</span>
            }
            else if (Model.Status == "Завершен")
            {
                <span class="badge bg-secondary">@Model.Status</span>
            }
            else
            {
                <span class="badge bg-warning">@Model.Status</span>
            }
        </dd>
        
        <dt class="col-sm-3">Примечания</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Notes)</dd>
        
        <dt class="col-sm-3">Создал</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.CreatedByUser.FullName)</dd>
        
        <dt class="col-sm-3">Дата создания</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.CreatedAt)</dd>
    </dl>
</div>

<div class="card mt-3">
    <div class="card-header">
        <h5>Информация о клиенте</h5>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ИНН</dt>
            <dd class="col-sm-9">@Model.Person.INN</dd>
            
            <dt class="col-sm-3">Телефон</dt>
            <dd class="col-sm-9">@Model.Person.Phone</dd>
            
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Person.Email</dd>
            
            <dt class="col-sm-3">Адрес</dt>
            <dd class="col-sm-9">@Model.Person.Address</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Изменить</a>
    <a asp-action="Index" class="btn btn-secondary">Назад к списку</a>
</div>
