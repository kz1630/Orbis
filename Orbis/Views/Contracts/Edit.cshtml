@model Orbis.Models.Contract

@{
    ViewData["Title"] = "Редактировать договор";
}

<h1>Редактировать договор страхования</h1>

<hr />
<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="ContractNumber" class="control-label">Номер договора</label>
                        <input asp-for="ContractNumber" class="form-control" />
                        <span asp-validation-for="ContractNumber" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="ContractDate" class="control-label">Дата заключения</label>
                        <input asp-for="ContractDate" type="date" class="form-control" />
                        <span asp-validation-for="ContractDate" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="PersonId" class="control-label">Клиент</label>
                <select asp-for="PersonId" class="form-control" asp-items="ViewBag.PersonId"></select>
                <span asp-validation-for="PersonId" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="InsuranceServiceId" class="control-label">Услуга страхования</label>
                <select asp-for="InsuranceServiceId" class="form-control" asp-items="ViewBag.InsuranceServiceId"></select>
                <span asp-validation-for="InsuranceServiceId" class="text-danger"></span>
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="StartDate" class="control-label">Дата начала действия</label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                        <span asp-validation-for="StartDate" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="EndDate" class="control-label">Дата окончания действия</label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Amount" class="control-label">Сумма договора (руб.)</label>
                <input asp-for="Amount" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label">Статус</label>
                <select asp-for="Status" class="form-control">
                    <option value="Активный">Активный</option>
                    <option value="Завершен">Завершен</option>
                    <option value="Просрочен">Просрочен</option>
                    <option value="Расторгнут">Расторгнут</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="CreatedByUserId" class="control-label">Создал (пользователь)</label>
                <select asp-for="CreatedByUserId" class="form-control" asp-items="ViewBag.CreatedByUserId">
                    <option value="">-- Не указан --</option>
                </select>
                <span asp-validation-for="CreatedByUserId" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Notes" class="control-label">Примечания</label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Сохранить" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Назад к списку</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
