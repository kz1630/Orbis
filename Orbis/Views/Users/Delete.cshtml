@model Orbis.Models.User

@{
    ViewData["Title"] = "Удалить пользователя";
}

<h1>Удалить пользователя</h1>

<h3>Вы уверены, что хотите удалить этого пользователя?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Логин</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Username)</dd>
        
        <dt class="col-sm-3">ФИО</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.FullName)</dd>
        
        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>
        
        <dt class="col-sm-3">Роль</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Role)</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Удалить" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Назад к списку</a>
    </form>
</div>
