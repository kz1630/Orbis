@{
    ViewData["Title"] = "Главная";
}

<div class="text-center">
    <h1 class="display-4">Добро пожаловать в систему Orbis</h1>
    <p class="lead">Программная система управления страховым агентством</p>
</div>

<div class="row mt-5">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-header">Договоры</div>
            <div class="card-body">
                <h5 class="card-title">Управление договорами</h5>
                <p class="card-text">Регистрация, поиск и управление страховыми договорами</p>
                <a asp-controller="Contracts" asp-action="Index" class="btn btn-light">Перейти</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-header">Клиенты</div>
            <div class="card-body">
                <h5 class="card-title">Справочник лиц</h5>
                <p class="card-text">Управление физическими и юридическими лицами</p>
                <a asp-controller="Persons" asp-action="Index" class="btn btn-light">Перейти</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card text-white bg-info mb-3">
            <div class="card-header">Услуги</div>
            <div class="card-body">
                <h5 class="card-title">Страховые услуги</h5>
                <p class="card-text">Справочник услуг страхования</p>
                <a asp-controller="InsuranceServices" asp-action="Index" class="btn btn-light">Перейти</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-header">Отчеты</div>
            <div class="card-body">
                <h5 class="card-title">Аналитика</h5>
                <p class="card-text">Отчеты и проблемные договоры</p>
                <a asp-controller="Contracts" asp-action="Report" class="btn btn-light">Перейти</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-dark text-white">
                <h5>Функции системы</h5>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">✓ Поддержка различных типов пользователей (Администратор, Менеджер, Пользователь)</li>
                    <li class="list-group-item">✓ Справочник услуг страхования с категориями и стоимостью</li>
                    <li class="list-group-item">✓ Регистрация и управление договорами страхования</li>
                    <li class="list-group-item">✓ Справочник физических и юридических лиц</li>
                    <li class="list-group-item">✓ Вывод сведений по страховым договорам за выбранный период</li>
                    <li class="list-group-item">✓ Поиск договоров по различным критериям (номер, клиент, услуга, статус, период)</li>
                    <li class="list-group-item">✓ Автоматический вывод сведений по "проблемным" договорам (просроченные, истекающие)</li>
                </ul>
            </div>
        </div>
    </div>
</div>
